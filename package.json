{
    "name": "claude-chat-mockup",
    "version": "0.1.0",
    "type": "module",
    "description": "An illustrative claude.ai chat UI component for landing pages and documentation.",
    "author": "Zach Grimaldi",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zpg6/claude-chat-mockup.git"
    },
    "bugs": {
        "url": "https://github.com/zpg6/claude-chat-mockup/issues"
    },
    "keywords": [
        "claude",
        "anthropic",
        "hero",
        "landing-page",
        "chat",
        "ui",
        "react",
        "component",
        "marketing",
        "mockup"
    ],
    "sideEffects": [
        "*.css"
    ],
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.mjs"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        },
        "./react": {
            "import": {
                "types": "./dist/react.d.ts",
                "default": "./dist/react.mjs"
            },
            "require": {
                "types": "./dist/react.d.cts",
                "default": "./dist/react.cjs"
            }
        },
        "./style.css": "./dist/style.css",
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "unbuild --clean",
        "dev": "unbuild --stub",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run build",
        "prepare": "husky"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.1.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "husky": "^9.1.7",
        "jsdom": "^25.0.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.2",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.7.0",
        "unbuild": "^3.0.0",
        "vitest": "^3.0.0"
    },
    "lint-staged": {
        "*": "prettier --write --ignore-unknown"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "publishConfig": {
        "access": "public"
    }
}
